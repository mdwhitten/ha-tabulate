#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Log exit of Tabulate backend
# ==============================================================================

bashio::log.info "Tabulate backend stopped (exit code: ${1})"

if [ "${1}" -ne 0 ] && [ "${1}" -ne 256 ]; then
    bashio::log.warning "Tabulate backend crashed, restarting..."
fi
