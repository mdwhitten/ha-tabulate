#!/command/with-contenv sh
# ==============================================================================
# Start Tabulate backend (FastAPI + uvicorn)
# ==============================================================================

# Read config from HA add-on options
ANTHROPIC_API_KEY=$(jq -r '.anthropic_api_key' /data/options.json)

export ANTHROPIC_API_KEY
export DB_PATH="/data/tabulate.db"
export IMAGE_DIR="/data/images"

echo "[tabulate] Starting Tabulate backend..."

cd /app || exit 1

exec uvicorn main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --no-access-log
